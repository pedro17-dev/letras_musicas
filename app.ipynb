    "import requests\n",
    "\n",
    "def album(banda, musica):\n",
    "    endpoint = f\"https://api.deezer.com/search?q=artist:%22{banda}%22%20album:%22{musica}%22\"\n",
    "    response = requests.get(endpoint)\n",
    "    return response.json() if response.status_code == 200 else {}"
